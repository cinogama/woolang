import woo::std;
import woo::debug;

func main()
{
    let m = {}mut: map<int, int>;
    do m->get_or_set_do(
        0,
        func()
        {
            let a = std::debug::traceback(-1);

            for (let s : a)
            {
                std::println(s->to_string);

                std::panic("Test");
            }

            return 6;
        });
}

main();