import woo::std;
import test_tool;

namespace test_operator_overload
{
    using SpString = string
    {
        func operator + (a: SpString, b:int)
        {
            return a as string + b as string;
        }
        func operator * (a: SpString, b:int)
        {
            let mut result = "";
            for (let mut i = 0; i<b; i+=1)
                result += a as string;
            return result;
        }
        func operator /(a, b)
        {
            std::println("Helloworld~");
            return a as string + "/" + b;
        }
        func operator %(a, b)
        {
            return (a + b as int) as SpString;
        }
    }
    
    func bar()
    {
        std::println("foo called~");

        return struct{m=mut "dsa" as SpString};
    }

    func main()
    {
        test_equal("Hello" as SpString + 25, "Hello25");
        test_equal("Hello" as SpString * 3, "HelloHelloHello");

        let mut str = "example";
        str = str as SpString + 123;
        test_equal(str, "example123");

        let mut spstr = str as SpString;
        spstr %= 321;
        test_equal(spstr as string, "example123321");

        let state = std::mutable::create(0);
        let structdat = struct{m = mut "data_struct" as SpString};
        let foo = func(){state->set(state->get + 1); return structdat;};

        foo().m %= foo().m as string;
        test_equal(structdat.m as string, "data_struct0");
        test_equal(state->get, 2);

        let mut v = 856;
        foo().m %= 123 * v;
        test_equal(structdat.m as string, "data_struct0105288");
        test_equal(state->get, 3);
        
        test_equal((bar().m %:= 133) as string, "dsa133");
        test_equal("abc" as SpString / "111", "abc/111");
        test_equal("abc" as SpString / ("111" as SpString + 5), "abc/1115");

        let mut a = "654" as SpString;
        a %= 321;
        test_equal((a %:= \=789;()) as string, "654321789");
        test_equal(a as string, "654321789");
    }
}

test_function("test_operator_overload.main", test_operator_overload::main);