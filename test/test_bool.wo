import woo::std;
import test_tool;

namespace test_bool
{
    func foo_true(val: bool)
    {
        test_assure(val== true);
    }
    func foo_false(val: bool)
    {
        test_assure(val == false);
    }
    func main()
    {
        let mut a = 5 as bool;
        test_assure(a == true);
        test_assure(a != false);

        test_assure(!(12 as bool) == false);
        test_assure(!a == false);
        test_assure(!(256 as bool) == false);

        let mut dynx = nil as dynamic;
        test_assure(dynx is bool == false);

        dynx = true as bool as dynamic;
        test_assure(dynx is bool);

        dynx = (!(dynx as bool)) as dynamic;
        test_assure(dynx is bool);

        dynx = 233 as dynamic;
        test_assure(dynx is bool == false);

        dynx = dynx as int as bool as dynamic;
        test_assure(dynx is bool);
        test_assure(0b01100 == dynx->unsafe::cast:<int>); // Holy shit!

    }
}

test_function("test_bool.main", test_bool::main);
