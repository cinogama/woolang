import woo::std;
import test_tool;

import pkg::dumpling;
import pkg::buffer;
import pkg::thread;

namespace test_vm
{
    func load_and_create_vmm(src:string)
    {
        let vmm = dumpling::Program::create(
            "test_vm/test_tmp_script.wo", src: buffer)->unwrap;
        return vmm;
    }
    
    func farcall_wrap_test()
    {
        let vmm = load_and_create_vmm(
            @"
            import woo::std; 
            let mut s2 = "Helloworld2"; 
            func super_depth_foo(f: ()=> string, s: string, n: int)=> void
            {
                if (n <= 0)
                    std::println(s, s2, f());
                else
                    super_depth_foo(f, s, n - 1);
            }
            
            extern func main()
            {
                let mut s = "Helloworld"; 
                return \f: ()=> string = super_depth_foo(f, s, 10000000);;
            }
            "@
            );
        return vmm->unsafe::load_extern:<(()=>string)=>void>("main")->unwrap;
    }
    
    func main()
    {
        let wraped_func_a = farcall_wrap_test();
        let wraped_func_b = farcall_wrap_test();
        let th = thread::create(
            func()
            {
                let mut x = "This is";
                wraped_func_a(\=x;);
                wraped_func_b(\=x;);
                x += " a test";
                std::sleep(40.);
                x += " for farcall::wrap";
                wraped_func_a(\=x;);
                wraped_func_b(\=x;);
            }
        );
        defer do th->wait;
        
        do load_and_create_vmm(
            @"
            import woo::std;
            func main()
            {
                std::println("Hey! This inform come from another vm!~");
            }
            main();
            "@
            );
                    
        // Test memmory leak
        let mut i = 0;
        while (i < 1000)
        {
            i += 1;
            do load_and_create_vmm(
                @"
                import woo::std;
                func test_template< T >(n:T)
                {
                    return n;
                }
                func main()
                {
                    let a = [1,2,3,4,5];
                    
                    do test_template(233);
                    do test_template("My world!");
                    do a;
                }
                main();
                "@
                );
        }
    }
}

test_function("test_vm.main", test_vm::main);
