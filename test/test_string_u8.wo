import woo::std;

import pkg::thread;

import test_tool;

namespace test_string_u8
{
    func main()
    {
        test_equal("", "");
        test_assure("\0" != "");
        test_equal("\0"->len(), 1);
        test_equal("\0"->cchars()->len(), 1);
        test_equal("\0"->chars()->len(), 1);
        test_equal("\0"->cchars()[0], '\0' as int as cchar);
        test_equal("\0"->chars()[0], '\0');

        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"[0], 'рҹҚү');
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"[1], 'е’Ң');
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"[2], 'рҹҚҺ');
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"[3], 'йғҪ');
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"[4], 'жҳҜ');
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"->len, "рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"->chars->len);
        test_equal("рҹҚүе’ҢрҹҚҺйғҪжҳҜж°ҙжһң"->len, 7);

        test_equal("дҪ еҘҪдё–з•Ң"[2], 'дё–');
        test_equal("дҪ еҘҪ\0дё–з•Ң"[2], '\0');
        test_equal("дҪ еҘҪ\0дё–з•Ң"[3], 'дё–');
        test_equal("дҪ еҘҪ\0дё–з•Ң"[4], 'з•Ң');
        test_equal("дҪ еҘҪ\0дё–з•Ң"->len, 5);
        test_equal("дҪ еҘҪ\0дё–з•Ң"->chars->len, 5);

        test_equal("abcdef"->find("zzz")->or(-1), -1);
        test_equal("abcdef"->find("cd")->or(-1), 2);
        test_equal("abcdef"->find_from("cd", 3)->or(-1), -1);
        test_equal("abcdefcd"->find("cd")->or(-1), 2);
        test_equal("abcdefcd"->rfind("cd")->or(-1), 6);
        test_equal("abcdefcd"->find_from("cd", 4)->or(-1), 6);
        test_equal("abcdefcd"->rfind_from("cd", 4)->or(-1), 2);

        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->find("ab")->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind("ab")->or(-1), 8);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->find_from("ab", 2)->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->find_from("ab", 3)->or(-1), 8);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind_from("ab", 6)->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind_from("ab", 3)->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind_from("abc", 3)->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind_from("abc", 4)->or(-1), 2);
        test_equal("дёӯж–Үabcdдёӯж–Үabcd"->rfind_from("ab", 2)->or(-1), -1);

        let str = "Helloworld";
        test_equal(str, "Helloworld");
        test_equal(str->sub_len(0, 5), "Hello");
        test_equal(str[0], 'H');
        test_equal(str[1], 'e');
        test_equal(str[2], 'l');
        test_equal(str[3], 'l');

        let chstr = "дҪ еҘҪдё–з•Ң";
        test_equal(chstr, "дҪ еҘҪдё–з•Ң");
        test_equal(chstr->sub_len(0, 2), "дҪ еҘҪ");
        test_equal(chstr[0], 'дҪ ');
        test_equal(chstr[1], 'еҘҪ');
        test_equal(chstr[2], 'дё–');
        test_equal(chstr[3], 'з•Ң');

        let combine = str->sub_len(0, 5) + chstr->sub_len(2, 2);
        test_equal(combine, "Helloдё–з•Ң");
        test_equal(combine->len(), 7);

        test_equal(""->len(), 0);
        test_equal("ABC"->len(), 3);
        test_equal("дҪ еҘҪ"->len(), 2);

        let wchars = combine->chars() as array<char>;
        let cchars = combine->cchars() as array<cchar>;

        test_assure(wchars->len != cchars->len);
        test_equal(wchars->str(), cchars->cstr());

        // Cannot crash when meet bad string.
        let badstr_1 = "дҪ еҘҪдё–з•Ң"->chars->>\ch=ch as int as cchar;->cstr;
        std::println("\n", F"BAD_STRING SIZE {badstr_1->len}= ", badstr_1);
        for (let mut i = 0; i < badstr_1->len; i += 1)
            std::print(badstr_1[i], "");
        
        let badstr_2 = "дҪ еҘҪдё–з•Ң"->cchars->>\ch=ch as int as char;->str;
        std::println("\n", F"BAD_STRING SIZE {badstr_2->len}= ", badstr_2);
        for (let mut i = 0; i < badstr_2->len; i += 1)
            std::print(badstr_2[i], "");

        let badstr_3 = F"дҪ еҘҪ{badstr_2}дё–з•Ң";
        std::println("\n", F"BAD_STRING SIZE {badstr_3->len}= ", badstr_3);
        for (let mut i = 0; i < badstr_3->len; i += 1)
            std::print(badstr_3[i], "");

        do do array::create(4, do nil)
            ->> \_ = thread::create(
                func()
                {
                    for (let mut r = 0; r < 1000; r += 1)
                    {
                        let bad_ch_set = F"дҪ еҘҪдё–з•Ң"->cchars;
                        let badstr_r = [1, 2, 3, 4, 5, 6, 7]mut
                            ->> \_ = std::rand(0, bad_ch_set->len - 1);
                            ->> \idx = bad_ch_set[idx];
                            ->  cstr;
                        
                        test_assure(badstr_r->len <= 7);
                        test_equal(badstr_r as string->len, badstr_r->chars as array<char>->len);
                        test_assure(badstr_r as string->len <= badstr_r->cchars as array<cchar>->len);
                        
                        std::print(badstr_r, "");

                        for (let mut i = 0; i < badstr_r->len; i += 1)
                            std::print(badstr_r[i], "");
                    }
                });
            ->> \t = t->wait;
            ->> \_ = thread::create(
                func()
                {
                    for (let mut r = 0; r < 100000; r += 1)
                    {
                        let bad_ch_set = F"дҪ еҘҪдё–з•Ң"->cchars;
                        let badstr_r = [1, 2, 3, 4, 5, 6, 7]mut
                            ->> \_ = std::rand(0, bad_ch_set->len - 1);
                            ->> \idx = bad_ch_set[idx];
                            ->  cstr;
                        
                        test_assure(badstr_r->len <= 7);
                        test_equal(badstr_r as string->len, badstr_r->chars as array<char>->len);
                        test_assure(badstr_r as string->len <= badstr_r->cchars as array<cchar>->len);
                    }
                });
            ->> \t = t->wait;
            ;

        test_equal("ГұoГұo"->len, 4);
        test_equal("ГұoГұo"[0], 'Гұ');
        test_equal("ГұoГұo"[1], 'o');
        test_equal("ГұoГұo"[2], 'Гұ');
        test_equal("ГұoГұo"[3], 'o');

        test_equal("Гј"->len, 1);
        test_equal("Гј"[0], 'Гј');
        test_equal("Гң"[0], 'Гң');

        test_equal("cafГ©"->len, 4);
        test_equal("cafГ©"[3], 'Г©');

        test_equal("ОұОІОі"->len, 3);
        test_equal("ОұОІОі"[0], 'Оұ');
        test_equal("ОұОІОі"[1], 'ОІ');
        test_equal("ОұОІОі"[2], 'Оі');

        test_equal("О‘О’О“"[0], 'О‘');
        test_equal("О‘О’О“"[2], 'О“');

        test_equal("РҙРҫРұСҖРҫ"->len, 5);
        test_equal("РҙРҫРұСҖРҫ"[0], 'Рҙ');
        test_equal("РҙРҫРұСҖРҫ"[4], 'Рҫ');

        test_equal("aГұoдё–рҹҚү"->len, 5);
        test_equal("aГұoдё–рҹҚү"[0], 'a');
        test_equal("aГұoдё–рҹҚү"[1], 'Гұ');
        test_equal("aГұoдё–рҹҚү"[2], 'o');
        test_equal("aГұoдё–рҹҚү"[3], 'дё–');
        test_equal("aГұoдё–рҹҚү"[4], 'рҹҚү');

        test_equal("aГұoдё–рҹҚү"->sub_len(0, 2), "aГұ");
        test_equal("aГұoдё–рҹҚү"->sub_len(1, 3), "Гұoдё–");

        test_equal("Оұ1ОІ2Оі3"->sub_len(2, 3), "ОІ2Оі");
        test_equal("Оұ1ОІ2Оі3"[0], 'Оұ');
        test_equal("Оұ1ОІ2Оі3"[2], 'ОІ');
        test_equal("Оұ1ОІ2Оі3"->len, 6);

        test_equal("helloОұОІОіworld"->find("ОұОІОі")->or(-1), 5);
        test_equal("helloОұОІОіworld"->find("ОұОІ")->or(-1), 5);
        test_equal("helloОұОІОіworld"->find("ОІОі")->or(-1), 6);

        test_equal("aГұoдё–рҹҚү"->find("Гұo")->or(-1), 1);
        test_equal("aГұoдё–рҹҚү"->find("дё–")->or(-1), 3);
        test_equal("aГұoдё–рҹҚү"->find("рҹҚү")->or(-1), 4);

        test_equal("aГұoдё–aГұoдё–"->rfind("Гұo")->or(-1), 5);
        test_equal("aГұoдё–aГұoдё–"->find_from("Гұo", 3)->or(-1), 5);

        test_equal("ОұОұОұ"->find("ОұОұ")->or(-1), 0);
        test_equal("ОұОІОұ"->find("ОІОұ")->or(-1), 1);

        let mixchars = "aГұoдё–рҹҚү"->chars as array<char>;
        test_equal(mixchars->len, 5);
        let mixcchars = "aГұoдё–рҹҚү"->cchars as array<cchar>;
        test_assure(mixcchars->len > 5);

        test_equal(mixchars->str, "aГұoдё–рҹҚү");
        test_equal(mixcchars->cstr, "aГұoдё–рҹҚү");

        test_equal("aГұoдё–рҹҚү"->sub_len(0, 1), "a");
        test_equal("aГұoдё–рҹҚү"->sub_len(1, 1), "Гұ");
        test_equal("aГұoдё–рҹҚү"->sub_len(4, 1), "рҹҚү");
        test_equal("aГұoдё–рҹҚү"->sub_len(0, 5), "aГұoдё–рҹҚү");

        test_equal("ОұОІОі"->sub_len(0, 2), "ОұОІ");
        test_equal("ОұОІОі"->sub_len(1, 1), "ОІ");
    }
}

test_function("test_string_u8.main", test_string_u8::main);
